---
interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string | null;
  color?: string;
  tags?: string[];
  index?: number;
  fontPairing?: string;
}

const { title, type, href, slug, image, color, tags, index = 0, fontPairing } = Astro.props;

const typeColorMap: Record<string, string> = {
  'futures': 'var(--color-cherry)',
  'case study': 'var(--color-lime)',
  'idea': '#ffffff',
};
const pillColor = typeColorMap[type] ?? '#ffffff';

const resolvedImage = image && !image.startsWith('/') && !image.startsWith('http') ? `/${image}` : image;

const pillText = [...(tags || []), type].join(' ');
---

<a
  href={href}
  class:list={['poster-card', fontPairing ? `font-pair-${fontPairing}` : '']}
  data-post={slug}
  style={`--i: ${index}; --pill-color: ${pillColor}; ${color ? `--poster-bg: ${color};` : ''}`}
>
  {resolvedImage && (
    <img src={resolvedImage} alt={title} class="poster-card__image" />
  )}
  <div class="poster-card__overlay">
    <h2 class="poster-card__title">{title}</h2>
    <div class="poster-card__pill">
      <span class="poster-card__type">{pillText}</span>
    </div>
  </div>
</a>

<style>
  .poster-card {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 64px;
    overflow: hidden;
    text-decoration: none;
    background: var(--poster-bg, var(--color-dark));
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
    transition: transform 0.4s var(--transition-spring);
  }

  .poster-card:hover {
    transform: scale(1.01);
  }

  .poster-card:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 4px;
  }

  .poster-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .poster-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1;
    padding: 32px;
  }

  .poster-card__title {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 700;
    line-height: 1.25;
    color: white;
    text-align: center;
    text-transform: var(--font-display-transform);
  }

  .poster-card__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-dark);
    padding: 2px 6px;
    margin-top: 16px;
  }

  .poster-card__type {
    font-family: 'Geist Mono', monospace;
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    color: var(--pill-color);
    white-space: nowrap;
    line-height: 1;
  }

  @media (max-width: 1024px) {
    .poster-card {
      border-radius: 48px;
    }

    .poster-card__overlay {
      padding: 24px;
    }

    .poster-card__title {
      font-size: 48px;
    }
  }

  @media (max-width: 640px) {
    .poster-card {
      border-radius: 32px;
    }

    .poster-card__overlay {
      padding: 16px;
    }

    .poster-card__title {
      font-size: 24px;
    }
  }
</style>
