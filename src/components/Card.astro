---
interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  wide?: boolean;
}

const { title, description, date, type, href, image, color, tags, index = 0, wide = false } =
  Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={href}
  class:list={['card', { 'card--wide': wide }]}
  style={`--i: ${index};${color ? ` --card-accent: ${color};` : ''}`}
>
  {image && <img src={image} alt={title} class="card__image" />}
  <span class="card__type">{type}</span>
  <h2 class="card__title">{title}</h2>
  <p class="card__description">{description}</p>
  <time class="card__date" datetime={date.toISOString()}>{formattedDate}</time>
  {
    tags && tags.length > 0 && (
      <div class="card__tags">
        {tags.map((tag) => (
          <span class="card__tag">{tag}</span>
        ))}
      </div>
    )
  }
</a>
