---
import Post from '../../layouts/Post.astro';
import SaturatedFieldDetail from './details/SaturatedFieldDetail.astro';
import ContainedBoxDetail from './details/ContainedBoxDetail.astro';
import BinarySplitDetail from './details/BinarySplitDetail.astro';
import type { VibeName, FontPairing } from './vibeDefaults';
import { getVibeProps } from './vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibe?: VibeName;
  vibeProps?: Record<string, string>;
  fontPairing?: FontPairing;
}

const { vibe, vibeProps: rawVibeProps, fontPairing, ...rest } = Astro.props;
const resolvedProps = vibe ? getVibeProps(vibe, rawVibeProps) : {};
---

{!vibe && <Post {...rest} fontPairing={fontPairing}><slot /></Post>}
{vibe === 'saturated-field' && <SaturatedFieldDetail {...rest} vibeProps={resolvedProps} fontPairing={fontPairing}><slot /></SaturatedFieldDetail>}
{vibe === 'contained-box' && <ContainedBoxDetail {...rest} vibeProps={resolvedProps} fontPairing={fontPairing}><slot /></ContainedBoxDetail>}
{vibe === 'binary-split' && <BinarySplitDetail {...rest} vibeProps={resolvedProps} fontPairing={fontPairing}><slot /></BinarySplitDetail>}
