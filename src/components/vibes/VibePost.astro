---
import Post from '../../layouts/Post.astro';
import SaturatedFieldDetail from './details/SaturatedFieldDetail.astro';
import type { FontPairing } from './vibeDefaults';
import { getVibeProps } from './vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps?: Record<string, string>;
  fontPairing?: FontPairing;
  hideTitle?: boolean;
  footer?: string;
}

const { vibeProps: rawVibeProps, fontPairing, ...rest } = Astro.props;
const resolvedProps = getVibeProps('saturated-field', rawVibeProps);
---

<SaturatedFieldDetail {...rest} vibeProps={resolvedProps} fontPairing={fontPairing}><slot /></SaturatedFieldDetail>
