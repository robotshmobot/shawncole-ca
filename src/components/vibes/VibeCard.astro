---
import Card from '../Card.astro';
import SaturatedFieldCard from './cards/SaturatedFieldCard.astro';
import type { FontPairing } from './vibeDefaults';
import { getVibeProps } from './vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  span?: string;
  vibeProps?: Record<string, string>;
  customStyles?: string;
  cardCustomStyles?: string;
  fontPairing?: FontPairing;
  hideTitle?: boolean;
}

const { vibeProps: rawVibeProps, span, fontPairing, ...rest } = Astro.props;
const resolvedProps = getVibeProps('saturated-field', rawVibeProps);
---

<div class={fontPairing ? `font-pair-${fontPairing}` : ''}>
  <SaturatedFieldCard {...rest} vibeProps={resolvedProps} />
</div>
