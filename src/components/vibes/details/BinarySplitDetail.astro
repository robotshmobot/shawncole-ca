---
import Base from '../../../layouts/Base.astro';
import { ensureContrast } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps: Record<string, string>;
  fontPairing?: string;
}

const { title, description, date, type, image, color, tags, customStyles, vibeProps, fontPairing } = Astro.props;
const splitRatio = vibeProps.splitRatio ?? '42';
const leftBg = vibeProps.leftBg ?? color ?? '#1a2744';
const rightBg = vibeProps.rightBg ?? '#ffffff';
const leftRadius = vibeProps.leftRadius ?? '0';
const flip = vibeProps.flip === 'true';
const leftTextColor = ensureContrast(leftBg, '#f5f0eb');
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class="vibe-binary-split-detail">
    <div class:list={['vibe-binary-split-detail__hero', { 'vibe-binary-split-detail__hero--flip': flip }]}
         style={`--split: ${splitRatio}%; --left-bg: ${leftBg}; --right-bg: ${rightBg}; --left-radius: ${leftRadius}px; --left-text: ${leftTextColor};`}>
      <div class="vibe-binary-split-detail__left">
        <span class="post__type" style={`color: ${leftTextColor}; opacity: 0.7;`}>{type}</span>
        <h1 class="post__title">{title}</h1>
        <p class="post__meta">{formattedDate}</p>
      </div>
      <div class="vibe-binary-split-detail__right">
        {image && <img src={image} alt={title} />}
      </div>
    </div>
    <div class="vibe-binary-split-detail__content">
      <div class="post__content">
        <slot />
      </div>
      {tags && tags.length > 0 && (
        <div class="card__tags" style="margin-top: var(--space-md)">
          {tags.map(tag => <span class="card__tag">{tag}</span>)}
        </div>
      )}
    </div>
  </article>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .vibe-binary-split-detail__hero {
    display: grid;
    grid-template-columns: var(--split) 1fr;
    min-height: 60vh;
  }
  .vibe-binary-split-detail__hero--flip {
    direction: rtl;
  }
  .vibe-binary-split-detail__hero--flip > * {
    direction: ltr;
  }
  .vibe-binary-split-detail__left {
    background: var(--left-bg);
    color: var(--left-text);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-radius: 0 var(--left-radius) var(--left-radius) 0;
  }
  .vibe-binary-split-detail__back {
    color: var(--left-text);
    opacity: 0.6;
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: auto;
    transition: opacity 0.3s;
  }
  .vibe-binary-split-detail__back:hover {
    opacity: 1;
  }
  .vibe-binary-split-detail__left .post__type {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .vibe-binary-split-detail__left .post__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    margin: var(--space-xs) 0;
    text-transform: var(--font-display-transform);
  }
  .vibe-binary-split-detail__left .post__meta {
    opacity: 0.5;
    font-size: 0.85rem;
  }
  .vibe-binary-split-detail__right {
    background: var(--right-bg);
    overflow: hidden;
  }
  .vibe-binary-split-detail__right img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .vibe-binary-split-detail__content {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
  }
  .vibe-binary-split-detail__content .post__content {
    font-size: 1.1rem;
    line-height: 1.8;
  }
  .vibe-binary-split-detail__content .post__content h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin: var(--space-md) 0 var(--space-sm);
    text-transform: var(--font-display-transform);
  }
  .vibe-binary-split-detail__content .post__content h3 {
    font-size: 1.3rem;
    margin: var(--space-sm) 0 var(--space-xs);
  }
  .vibe-binary-split-detail__content .post__content p {
    margin-bottom: var(--space-sm);
  }
  .vibe-binary-split-detail__content .post__content blockquote {
    border-left: 3px solid var(--left-bg);
    padding-left: var(--space-sm);
    color: var(--color-muted);
    font-style: italic;
    margin: var(--space-sm) 0;
  }
  .vibe-binary-split-detail__content .post__content a {
    color: var(--left-bg);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .vibe-binary-split-detail__content .post__content code {
    background: var(--color-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .vibe-binary-split-detail__content .post__content pre {
    background: var(--color-text);
    color: var(--color-bg);
    padding: var(--space-sm);
    border-radius: var(--radius);
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }
  .vibe-binary-split-detail__content .post__content pre code {
    background: none;
    padding: 0;
  }
  @media (max-width: 720px) {
    .vibe-binary-split-detail__hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .vibe-binary-split-detail__hero--flip {
      direction: ltr;
    }
    .vibe-binary-split-detail__left {
      border-radius: 0;
      padding: var(--space-md);
      min-height: 40vh;
    }
    .vibe-binary-split-detail__right {
      max-height: 300px;
    }
  }
</style>
