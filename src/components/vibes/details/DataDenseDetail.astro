---
import Base from '../../../layouts/Base.astro';
import { ensureContrast, getCompositionProps, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps: Record<string, string>;
  fontPairing?: string;
}

const { title, description, date, type, image, color, tags, customStyles, vibeProps, fontPairing } = Astro.props;
const fieldColor = vibeProps.fieldColor ?? '#0a0a0a';
const gridColor = ensureContrast(fieldColor, vibeProps.gridColor ?? '#00ff88');
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compClass = compositionClasses(cp);

const metaLines = [
  `TYPE: ${type.toUpperCase()}`,
  `DATE: ${formattedDate.toUpperCase()}`,
  `WORDS: ${description.split(' ').length}`,
  `CHARS: ${description.length}`,
];
if (tags) tags.forEach(t => metaLines.push(`TAG: ${t.toUpperCase()}`));
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class:list={['vibe-data-dense-detail', compClass]} style={`--field-color: ${fieldColor}; --grid-color: ${gridColor};`}>
    <header class="vibe-data-dense-detail__header">
      <div class="vibe-data-dense-detail__meta-grid" aria-hidden="true">
        {metaLines.map(line => <span>{line}</span>)}
      </div>
      <div class="vibe-data-dense-detail__header-content">
        <span class="post__type">{type}</span>
        <h1 class="post__title">{title}</h1>
        <p class="post__meta">{formattedDate}</p>
      </div>
    </header>
    {image && <img src={image} alt={title} class="post__hero" />}
    <div class="post__content">
      <slot />
    </div>
    {tags && tags.length > 0 && (
      <div class="card__tags" style="margin-top: var(--space-md)">
        {tags.map(tag => <span class="card__tag" style={`background: rgba(255,255,255,0.08); color: ${gridColor};`}>{tag}</span>)}
      </div>
    )}
  </article>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .vibe-data-dense-detail {
    background: var(--field-color);
    color: var(--grid-color);
    min-height: 100vh;
    font-family: 'Geist Mono', monospace;
  }
  .vibe-data-dense-detail__header {
    position: relative;
    padding: var(--space-xl) var(--space-md) var(--space-lg);
    overflow: hidden;
  }
  .vibe-data-dense-detail__meta-grid {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-md);
    opacity: 0.15;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    line-height: 2;
    overflow: hidden;
  }
  .vibe-data-dense-detail__meta-grid span {
    white-space: nowrap;
  }
  .vibe-data-dense-detail__header-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }
  .vibe-data-dense-detail__back {
    display: inline-block;
    color: var(--grid-color);
    opacity: 0.6;
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
    transition: opacity 0.3s;
  }
  .vibe-data-dense-detail__back:hover { opacity: 1; }
  .vibe-data-dense-detail .post__type {
    color: var(--grid-color);
    opacity: 0.6;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .vibe-data-dense-detail .post__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin: var(--space-sm) 0;
    text-transform: var(--font-display-transform);
  }
  .vibe-data-dense-detail .post__meta {
    opacity: 0.4;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }
  .vibe-data-dense-detail .post__hero {
    max-width: 720px;
    width: 100%;
    margin: 0 auto var(--space-md);
    display: block;
    border-radius: var(--radius);
  }
  .vibe-data-dense-detail .post__content {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.8;
  }
  .vibe-data-dense-detail .post__content h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin: var(--space-md) 0 var(--space-sm);
    text-transform: var(--font-display-transform);
  }
  .vibe-data-dense-detail .post__content p { margin-bottom: var(--space-sm); }
  .vibe-data-dense-detail .post__content blockquote {
    border-left: 3px solid var(--grid-color);
    padding-left: var(--space-sm);
    opacity: 0.7;
    font-style: italic;
    margin: var(--space-sm) 0;
  }
  .vibe-data-dense-detail .post__content a {
    color: var(--grid-color);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .vibe-data-dense-detail .post__content code {
    background: rgba(255,255,255,0.08);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .vibe-data-dense-detail .post__content pre {
    background: rgba(255,255,255,0.05);
    padding: var(--space-sm);
    border-radius: var(--radius);
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }
  .vibe-data-dense-detail .card__tags {
    max-width: 720px;
    margin: var(--space-md) auto 0;
    padding: 0 var(--space-md) var(--space-lg);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
