---
import Base from '../../../layouts/Base.astro';
import { ensureContrast } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps: Record<string, string>;
  fontPairing?: string;
  hideTitle?: boolean;
  footer?: string;
}

const { title, description, date, type, image, color, tags, customStyles, vibeProps, fontPairing, hideTitle, footer } = Astro.props;
const fieldColor = vibeProps.fieldColor ?? color ?? '#2a5aa8';
const textColor = ensureContrast(fieldColor, vibeProps.textColor ?? '#f5f0eb');
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class="detail" style={`--field-color: ${fieldColor}; --text-color: ${textColor};`}>
    <header class="detail__hero">
      {image && <img src={image} alt={title} class="detail__hero-image" />}
      {!hideTitle && (
        <div class="detail__hero-overlay">
          <div class="detail__pill">
            <span class="detail__type">{type}</span>
          </div>
          <h1 class="detail__title">{title}</h1>
        </div>
      )}
    </header>

    <div class="detail__body">
      <div class="detail__content">
        <slot />
      </div>
    </div>

    {footer && (
      <footer class="detail__footer">
        <div class="detail__footer-box" set:html={footer.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="detail__footer-link">$1</a>')} />
      </footer>
    )}
  </article>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .detail {
    background: var(--field-color);
    color: var(--text-color);
    min-height: 100vh;
    /* Negate body padding so detail page goes edge-to-edge within the 1600px max */
    margin-left: calc(-1 * var(--site-margin));
    margin-right: calc(-1 * var(--site-margin));
  }

  /* Hero: full-width image with title overlay */
  .detail__hero {
    position: relative;
    width: 100%;
    height: 66vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .detail__hero-overlay {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 64px;
  }

  .detail__pill {
    display: inline-flex;
    align-items: center;
    background: var(--color-dark, #12121A);
    padding: 6px 16px;
    margin-bottom: 24px;
  }

  .detail__type {
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
    color: var(--text-color);
  }

  .detail__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    text-transform: var(--font-display-transform);
    color: var(--text-color);
  }

  /* Body content */
  .detail__body {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 64px 0;
  }

  .detail__content {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .detail__content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin: var(--space-md) 0 var(--space-sm);
    text-transform: var(--font-display-transform);
  }

  .detail__content :global(p) {
    margin-bottom: var(--space-sm);
  }

  .detail__content :global(blockquote) {
    border-left: 3px solid var(--text-color);
    padding-left: var(--space-sm);
    opacity: 0.7;
    font-style: italic;
    margin: var(--space-sm) 0;
  }

  .detail__content :global(a) {
    color: var(--text-color);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .detail__content :global(img) {
    width: calc(100% + 128px);
    margin-left: -64px;
    height: auto;
    border-radius: 16px;
    margin-top: 32px;
    margin-bottom: 32px;
    display: block;
  }

  .detail__content :global(code) {
    background: rgba(255,255,255,0.1);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .detail__content :global(pre) {
    background: rgba(0,0,0,0.3);
    padding: var(--space-sm);
    border-radius: 16px;
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }

  .detail__content :global(hr) {
    border: none;
    width: 240px;
    height: 1px;
    background: var(--text-color);
    opacity: 0.2;
    margin: 64px auto;
  }

  .detail__content :global(strong) {
    font-weight: 600;
  }

  /* Footer */
  .detail__footer {
    padding: 64px 64px 120px;
  }

  .detail__footer-box {
    background: #ffffff;
    border-radius: 24px;
    padding: 48px;
    font-family: 'SRC Marker', var(--font-body);
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.5;
    text-transform: uppercase;
    color: var(--color-dark, #1a1a1a);
  }

  .detail__footer-box :global(.detail__footer-link) {
    color: var(--color-dark, #1a1a1a);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    font-weight: 700;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .detail__hero {
      height: 50vh;
    }

    .detail__hero-overlay {
      padding: 24px;
    }

    .detail__body {
      padding: 40px 24px 0;
    }

    .detail__content :global(img) {
      width: calc(100% + 48px);
      margin-left: -24px;
    }

    .detail__footer {
      padding: 40px 24px 120px;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .detail__hero {
      height: 50vh;
    }

    .detail__hero-overlay {
      padding: 16px;
    }

    .detail__title {
      font-size: 2rem;
    }

    .detail__body {
      padding: 32px 16px 0;
    }

    .detail__content :global(img) {
      width: calc(100% + 32px);
      margin-left: -16px;
    }

    .detail__footer {
      padding: 32px 16px 120px;
    }

    .detail__footer-box {
      padding: 24px;
      border-radius: 16px;
    }
  }
</style>
