---
import Base from '../../../layouts/Base.astro';
import { ensureContrast, getCompositionProps, compositionStyles, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps: Record<string, string>;
  fontPairing?: string;
  hideTitle?: boolean;
}

const { title, description, date, type, image, color, tags, customStyles, vibeProps, fontPairing, hideTitle } = Astro.props;
const fieldColor = vibeProps.fieldColor ?? '#f5f0eb';
const typeColor = ensureContrast(fieldColor, vibeProps.typeColor ?? '#1a1a1a');
const typeOpacity = vibeProps.typeOpacity ?? '0.06';
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compClass = compositionClasses(cp);
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class:list={['vibe-type-wall-detail', compClass]} style={`--field-color: ${fieldColor}; --type-color: ${typeColor}; --type-opacity: ${typeOpacity};`}>
    {!hideTitle && (
      <div class="vibe-type-wall-detail__hero">
        <div class="vibe-type-wall-detail__bg-type" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => (
            <span>{title}</span>
          ))}
        </div>
        <div class="vibe-type-wall-detail__hero-content">
          <span class="post__type">{type}</span>
          <h1 class="post__title">{title}</h1>
          <p class="post__meta">{formattedDate}</p>
        </div>
      </div>
    )}
    {image && <img src={image} alt={title} class="post__hero" />}
    <div class="post__content">
      <slot />
    </div>
    {tags && tags.length > 0 && (
      <div class="card__tags" style="margin-top: var(--space-md)">
        {tags.map(tag => <span class="card__tag">{tag}</span>)}
      </div>
    )}
  </article>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .vibe-type-wall-detail {
    background: var(--field-color);
    color: var(--type-color);
    min-height: 100vh;
  }
  .vibe-type-wall-detail__hero {
    position: relative;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding: var(--space-lg) var(--space-md);
  }
  .vibe-type-wall-detail__bg-type {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }
  .vibe-type-wall-detail__bg-type span {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 900;
    line-height: 0.9;
    text-transform: var(--font-display-transform, uppercase);
    white-space: nowrap;
    opacity: var(--type-opacity);
    color: var(--type-color);
  }
  .vibe-type-wall-detail__hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
  }
  .vibe-type-wall-detail__back {
    display: inline-block;
    color: var(--type-color);
    opacity: 0.6;
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
    transition: opacity 0.3s;
  }
  .vibe-type-wall-detail__back:hover { opacity: 1; }
  .vibe-type-wall-detail .post__type {
    color: var(--type-color);
    opacity: 0.6;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .vibe-type-wall-detail .post__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    margin: var(--space-sm) 0;
    text-transform: var(--font-display-transform);
  }
  .vibe-type-wall-detail .post__meta {
    opacity: 0.5;
    font-size: 0.85rem;
  }
  .vibe-type-wall-detail .post__hero {
    max-width: 720px;
    width: 100%;
    margin: 0 auto var(--space-md);
    display: block;
    border-radius: var(--radius);
  }
  .vibe-type-wall-detail .post__content {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
    font-size: 1.1rem;
    line-height: 1.8;
  }
  .vibe-type-wall-detail .post__content h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin: var(--space-md) 0 var(--space-sm);
    text-transform: var(--font-display-transform);
  }
  .vibe-type-wall-detail .post__content p { margin-bottom: var(--space-sm); }
  .vibe-type-wall-detail .post__content blockquote {
    border-left: 3px solid var(--type-color);
    padding-left: var(--space-sm);
    opacity: 0.7;
    font-style: italic;
    margin: var(--space-sm) 0;
  }
  .vibe-type-wall-detail .post__content a {
    color: var(--type-color);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .vibe-type-wall-detail .post__content code {
    background: rgba(0,0,0,0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .vibe-type-wall-detail .post__content pre {
    background: rgba(0,0,0,0.06);
    padding: var(--space-sm);
    border-radius: var(--radius);
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }
  .vibe-type-wall-detail .card__tags {
    max-width: 720px;
    margin: var(--space-md) auto 0;
    padding: 0 var(--space-md) var(--space-lg);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
