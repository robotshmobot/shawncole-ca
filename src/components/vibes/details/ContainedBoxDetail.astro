---
import Base from '../../../layouts/Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps: Record<string, string>;
  fontPairing?: string;
  hideTitle?: boolean;
}

const { title, description, date, type, image, color, tags, customStyles, vibeProps, fontPairing, hideTitle } = Astro.props;
const frameColor = vibeProps.frameColor ?? color ?? '#8b6914';
const frameWidth = vibeProps.frameWidth ?? '6';
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <div class="vibe-contained-box-detail-wrap">
    <article class="vibe-contained-box-detail" style={`--frame-color: ${frameColor}; --frame-width: ${frameWidth}px; --color-accent: ${frameColor};`}>
      {!hideTitle && (
        <header class="post__header">
          <span class="post__type" style={`color: ${frameColor};`}>{type}</span>
          <h1 class="post__title">{title}</h1>
          <p class="post__meta">{formattedDate}</p>
        </header>
      )}
      {image && <img src={image} alt={title} class="post__hero" />}
      <div class="post__content">
        <slot />
      </div>
      {tags && tags.length > 0 && (
        <div class="card__tags" style="margin-top: var(--space-md)">
          {tags.map(tag => <span class="card__tag">{tag}</span>)}
        </div>
      )}
    </article>
  </div>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .vibe-contained-box-detail-wrap {
    padding: var(--space-lg) var(--space-md);
    display: flex;
    justify-content: center;
  }
  .vibe-contained-box-detail {
    max-width: 800px;
    width: 100%;
    border: var(--frame-width) solid var(--frame-color);
    border-radius: 2px;
    padding: var(--space-lg);
    background: var(--color-surface);
    box-shadow: 6px 6px 0 rgba(0,0,0,0.08),
                inset 0 0 60px rgba(0,0,0,0.01);
  }
  .vibe-contained-box-detail .post__back {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
    transition: color 0.3s;
  }
  .vibe-contained-box-detail .post__back:hover {
    color: var(--color-text);
  }
  .vibe-contained-box-detail .post__header {
    margin-bottom: var(--space-lg);
  }
  .vibe-contained-box-detail .post__type {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .vibe-contained-box-detail .post__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin: var(--space-xs) 0;
    text-transform: var(--font-display-transform);
  }
  .vibe-contained-box-detail .post__meta {
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .vibe-contained-box-detail .post__hero {
    width: 100%;
    border-radius: 2px;
    margin-bottom: var(--space-md);
  }
  .vibe-contained-box-detail .post__content {
    font-size: 1.1rem;
    line-height: 1.8;
  }
  .vibe-contained-box-detail .post__content h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    margin: var(--space-md) 0 var(--space-sm);
    text-transform: var(--font-display-transform);
  }
  .vibe-contained-box-detail .post__content h3 {
    font-size: 1.3rem;
    margin: var(--space-sm) 0 var(--space-xs);
  }
  .vibe-contained-box-detail .post__content p {
    margin-bottom: var(--space-sm);
  }
  .vibe-contained-box-detail .post__content blockquote {
    border-left: 3px solid var(--frame-color);
    padding-left: var(--space-sm);
    color: var(--color-muted);
    font-style: italic;
    margin: var(--space-sm) 0;
  }
  .vibe-contained-box-detail .post__content a {
    color: var(--frame-color);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .vibe-contained-box-detail .post__content code {
    background: var(--color-bg);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .vibe-contained-box-detail .post__content pre {
    background: var(--color-text);
    color: var(--color-bg);
    padding: var(--space-sm);
    border-radius: 2px;
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }
  .vibe-contained-box-detail .post__content pre code {
    background: none;
    padding: 0;
  }
</style>
