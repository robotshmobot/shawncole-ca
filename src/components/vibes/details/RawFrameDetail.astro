---
import Base from '../../../layouts/Base.astro';
import { ensureContrast, getCompositionProps, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  vibeProps: Record<string, string>;
  fontPairing?: string;
  hideTitle?: boolean;
}

const { title, description, date, type, image, color, tags, customStyles, vibeProps, fontPairing, hideTitle } = Astro.props;
const layers = parseInt(vibeProps.layers ?? '2');
const offsetX = parseInt(vibeProps.offsetX ?? '12');
const offsetY = parseInt(vibeProps.offsetY ?? '8');
const shadowDepth = vibeProps.shadowDepth ?? 'medium';
const layerColorsStr = vibeProps.layerColors ?? '#6b4423,#f5f0eb';
const layerColors = layerColorsStr.split(',').map(c => c.trim());
const topColor = layerColors[layerColors.length - 1] || '#f5f0eb';
const textColor = ensureContrast(topColor, '#1a1a1a');
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compClass = compositionClasses(cp);

const shadowMap: Record<string, string> = {
  subtle: '0 4px 12px rgba(0,0,0,0.1)',
  medium: '0 8px 24px rgba(0,0,0,0.15)',
  deep: '0 16px 48px rgba(0,0,0,0.25)',
};
const shadow = shadowMap[shadowDepth] || shadowMap.medium;
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class:list={['vibe-raw-frame-detail', compClass]} style={`--top-color: ${topColor}; --text-color: ${textColor};`}>
    <div class="vibe-raw-frame-detail__frame">
      {Array.from({ length: layers }).map((_, i) => (
        <div
          class="vibe-raw-frame-detail__layer"
          style={`background: ${layerColors[i % layerColors.length]}; transform: translate(${i * offsetX}px, ${i * offsetY}px); box-shadow: ${shadow}; z-index: ${i};`}
        />
      ))}
      <div class="vibe-raw-frame-detail__top" style={`background: ${topColor}; transform: translate(${(layers - 1) * offsetX}px, ${(layers - 1) * offsetY}px); box-shadow: ${shadow}; z-index: ${layers};`}>
        {!hideTitle && (
          <header class="vibe-raw-frame-detail__header">
            <span class="post__type" style={`color: ${textColor}; opacity: 0.6;`}>{type}</span>
            <h1 class="post__title">{title}</h1>
            <p class="post__meta">{formattedDate}</p>
          </header>
        )}
        {image && <img src={image} alt={title} class="post__hero" />}
        <div class="post__content">
          <slot />
        </div>
        {tags && tags.length > 0 && (
          <div class="card__tags" style="margin-top: var(--space-md)">
            {tags.map(tag => <span class="card__tag">{tag}</span>)}
          </div>
        )}
      </div>
    </div>
  </article>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .vibe-raw-frame-detail {
    min-height: 100vh;
    padding: var(--space-lg) var(--space-md);
    color: var(--text-color);
  }
  .vibe-raw-frame-detail__frame {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .vibe-raw-frame-detail__layer {
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
  }
  .vibe-raw-frame-detail__top {
    position: relative;
    border-radius: var(--radius);
    padding: var(--space-lg) var(--space-md);
  }
  .vibe-raw-frame-detail__header {
    margin-bottom: var(--space-lg);
    padding-top: var(--space-md);
  }
  .vibe-raw-frame-detail .post__type {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .vibe-raw-frame-detail .post__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    margin: var(--space-sm) 0;
    text-transform: var(--font-display-transform);
  }
  .vibe-raw-frame-detail .post__meta { opacity: 0.5; font-size: 0.85rem; }
  .vibe-raw-frame-detail .post__hero {
    width: 100%;
    border-radius: calc(var(--radius) / 2);
    margin-bottom: var(--space-md);
  }
  .vibe-raw-frame-detail .post__content { font-size: 1.1rem; line-height: 1.8; }
  .vibe-raw-frame-detail .post__content h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    margin: var(--space-md) 0 var(--space-sm);
    text-transform: var(--font-display-transform);
  }
  .vibe-raw-frame-detail .post__content p { margin-bottom: var(--space-sm); }
  .vibe-raw-frame-detail .post__content blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-sm);
    color: var(--color-muted);
    font-style: italic;
    margin: var(--space-sm) 0;
  }
  .vibe-raw-frame-detail .post__content a {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .vibe-raw-frame-detail .post__content code {
    background: rgba(0,0,0,0.05);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .vibe-raw-frame-detail .post__content pre {
    background: rgba(0,0,0,0.05);
    padding: var(--space-sm);
    border-radius: var(--radius);
    overflow-x: auto;
    margin: var(--space-sm) 0;
  }
  .vibe-raw-frame-detail .card__tags { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
</style>
