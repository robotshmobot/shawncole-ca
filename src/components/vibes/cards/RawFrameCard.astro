---
import { ensureContrast, getCompositionProps, compositionStyles, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  vibeProps: Record<string, string>;
  cardCustomStyles?: string;
  hideTitle?: boolean;
}

const { title, description, date, type, href, slug, tags, index = 0, vibeProps, cardCustomStyles, hideTitle } = Astro.props;
const layers = parseInt(vibeProps.layers ?? '2');
const offsetX = parseInt(vibeProps.offsetX ?? '12');
const offsetY = parseInt(vibeProps.offsetY ?? '8');
const shadowDepth = vibeProps.shadowDepth ?? 'medium';
const layerColorsStr = vibeProps.layerColors ?? '#6b4423,#f5f0eb';
const layerColors = layerColorsStr.split(',').map(c => c.trim());
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compStyle = compositionStyles(cp);
const compClass = compositionClasses(cp);

const topColor = layerColors[layerColors.length - 1] || '#f5f0eb';
const textColor = ensureContrast(topColor, '#1a1a1a');

const shadowMap: Record<string, string> = {
  subtle: '0 4px 12px rgba(0,0,0,0.1)',
  medium: '0 8px 24px rgba(0,0,0,0.15)',
  deep: '0 16px 48px rgba(0,0,0,0.25)',
};
const shadow = shadowMap[shadowDepth] || shadowMap.medium;

const layerData: { color: string; x: number; y: number }[] = [];
for (let i = 0; i < layers; i++) {
  layerData.push({
    color: layerColors[i % layerColors.length] || '#ddd',
    x: i * offsetX,
    y: i * offsetY,
  });
}
---

<a
  href={href}
  class:list={['vibe-raw-frame-card', compClass]}
  data-post={slug}
  style={`--i: ${index}; --text-color: ${textColor}; --shadow: ${shadow}; --pad-right: ${(layers - 1) * offsetX}px; --pad-bottom: ${(layers - 1) * offsetY}px; ${compStyle}`}
>
  <div class="vibe-raw-frame-card__stack">
    {layerData.map((layer, i) => (
      <div
        class:list={['vibe-raw-frame-card__layer', { 'vibe-raw-frame-card__layer--top': i === layerData.length - 1 }]}
        style={`background: ${layer.color}; transform: translate(${layer.x}px, ${layer.y}px); box-shadow: ${shadow};`}
      >
        {i === layerData.length - 1 && (
          <div class="vibe-raw-frame-card__content">
            {!hideTitle && <span class="card__type">{type}</span>}
            {!hideTitle && <h2 class="card__title">{title}</h2>}
            {!hideTitle && <p class="card__description">{description}</p>}
            {!hideTitle && <time class="card__date" datetime={date.toISOString()}>{formattedDate}</time>}
          </div>
        )}
      </div>
    ))}
  </div>
</a>
{cardCustomStyles && <style set:html={cardCustomStyles.replaceAll(':card', `[data-post="${slug}"]`)} />}

<style>
  .vibe-raw-frame-card {
    display: block;
    text-decoration: none;
    color: var(--text-color);
    padding-right: var(--pad-right);
    padding-bottom: var(--pad-bottom);
    transition: transform 0.4s var(--transition-spring);
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
  }
  .vibe-raw-frame-card__stack {
    position: relative;
    min-height: 320px;
  }
  .vibe-raw-frame-card__layer {
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
  }
  .vibe-raw-frame-card__layer--top {
    position: relative;
    min-height: 320px;
  }
  .vibe-raw-frame-card__content {
    padding: 48px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .vibe-raw-frame-card .card__type {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: var(--space-xs);
  }
  .vibe-raw-frame-card .card__title {
    font-family: var(--font-display);
    font-size: calc(var(--title-scale, 1) * 1.6rem);
    font-weight: var(--title-weight, 400);
    line-height: var(--title-leading, 1.2);
    text-transform: var(--font-display-transform);
    margin-bottom: var(--space-xs);
  }
  .vibe-raw-frame-card .card__description {
    font-size: 0.95rem;
    opacity: 0.7;
    line-height: 1.5;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .vibe-raw-frame-card .card__date {
    font-size: 0.75rem;
    opacity: 0.5;
    letter-spacing: 0.05em;
    margin-top: auto;
  }
  .vibe-raw-frame-card:hover {
    transform: scale(1.02) rotate(-0.5deg);
  }
  .vibe-raw-frame-card:focus-visible {
    outline: 3px solid var(--text-color);
    outline-offset: 4px;
  }
</style>
