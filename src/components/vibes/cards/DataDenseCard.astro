---
import { ensureContrast, getCompositionProps, compositionStyles, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  vibeProps: Record<string, string>;
  cardCustomStyles?: string;
}

const { title, description, date, type, href, slug, tags, index = 0, vibeProps, cardCustomStyles } = Astro.props;
const fieldColor = vibeProps.fieldColor ?? '#0a0a0a';
const gridColor = ensureContrast(fieldColor, vibeProps.gridColor ?? '#00ff88');
const accentScale = vibeProps.accentScale ?? '4';
const gridDensity = vibeProps.gridDensity ?? 'tight';
const dataSource = vibeProps.dataSource ?? 'meta';
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compStyle = compositionStyles(cp);
const compClass = compositionClasses(cp);

const gridLines: string[] = [];
if (dataSource === 'tags' && tags) {
  tags.forEach(t => gridLines.push(t.toUpperCase()));
} else if (dataSource === 'content') {
  gridLines.push(...description.split(' ').slice(0, 30));
} else {
  gridLines.push(`TYPE: ${type.toUpperCase()}`);
  gridLines.push(`DATE: ${formattedDate.toUpperCase()}`);
  gridLines.push(`SLUG: ${slug.toUpperCase()}`);
  if (tags) tags.forEach(t => gridLines.push(`TAG: ${t.toUpperCase()}`));
  gridLines.push(`CHARS: ${description.length}`);
  gridLines.push(`WORDS: ${description.split(' ').length}`);
}
while (gridLines.length < 12) {
  gridLines.push(...gridLines.slice(0, 12 - gridLines.length));
}
---

<a
  href={href}
  class:list={['vibe-data-dense-card', `vibe-data-dense-card--${gridDensity}`, compClass]}
  data-post={slug}
  style={`--i: ${index}; --field-color: ${fieldColor}; --grid-color: ${gridColor}; --accent-scale: ${accentScale}; ${compStyle}`}
>
  <div class="vibe-data-dense-card__grid" aria-hidden="true">
    {gridLines.map(line => (
      <span class="vibe-data-dense-card__line">{line}</span>
    ))}
  </div>
  <div class="vibe-data-dense-card__focal">
    <span class="card__type">{type}</span>
    <h2 class="card__title">{title}</h2>
  </div>
  <time class="card__date" datetime={date.toISOString()}>{formattedDate}</time>
</a>
{cardCustomStyles && <style set:html={cardCustomStyles.replaceAll(':card', `[data-post="${slug}"]`)} />}

<style>
  .vibe-data-dense-card {
    display: flex;
    flex-direction: column;
    background: var(--field-color);
    color: var(--grid-color);
    text-decoration: none;
    padding: var(--density-pad, var(--space-md));
    min-height: 360px;
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    font-family: 'Geist Mono', monospace;
    transition: transform 0.4s var(--transition-spring);
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
  }
  .vibe-data-dense-card__grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    opacity: 0.3;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.6;
    overflow: hidden;
    flex: 1;
  }
  .vibe-data-dense-card--tight .vibe-data-dense-card__grid { line-height: 1.3; font-size: 0.55rem; }
  .vibe-data-dense-card--medium .vibe-data-dense-card__grid { line-height: 1.8; font-size: 0.65rem; }
  .vibe-data-dense-card--loose .vibe-data-dense-card__grid { line-height: 2.2; font-size: 0.7rem; }
  .vibe-data-dense-card__line {
    white-space: nowrap;
    overflow: hidden;
  }
  .vibe-data-dense-card__focal {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-md);
    right: var(--space-md);
    z-index: 1;
  }
  .vibe-data-dense-card__focal .card__type {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: var(--space-xs);
  }
  .vibe-data-dense-card__focal .card__title {
    font-family: var(--font-display);
    font-size: calc(var(--accent-scale) * 0.6rem);
    font-weight: 800;
    line-height: var(--title-leading, 1.0);
    text-transform: var(--font-display-transform);
    margin: 0;
  }
  .vibe-data-dense-card .card__date {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    font-size: 0.6rem;
    opacity: 0.4;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .vibe-data-dense-card:hover {
    transform: scale(1.01);
  }
  .vibe-data-dense-card:hover .vibe-data-dense-card__grid {
    opacity: 0.5;
  }
  .vibe-data-dense-card:focus-visible {
    outline: 3px solid var(--grid-color);
    outline-offset: 4px;
  }
</style>
