---
import { ensureContrast } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  vibeProps: Record<string, string>;
  cardCustomStyles?: string;
}

const { title, description, date, type, href, slug, tags, index = 0, vibeProps, cardCustomStyles } = Astro.props;
const fieldColor = vibeProps.fieldColor ?? '#2a5aa8';
const textColor = ensureContrast(fieldColor, vibeProps.textColor ?? '#f5f0eb');
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a
  href={href}
  class="vibe-saturated-field-card"
  data-post={slug}
  style={`--i: ${index}; --field-color: ${fieldColor}; --text-color: ${textColor};`}
>
  <div class="vibe-saturated-field-card__inner">
    <span class="card__type" style={`color: ${textColor}; opacity: 0.7;`}>{type}</span>
    <h2 class="card__title">{title}</h2>
  </div>
  <time class="card__date" datetime={date.toISOString()}>{formattedDate}</time>
  {tags && tags.length > 0 && (
    <div class="card__tags">
      {tags.map(tag => <span class="card__tag" style={`background: rgba(255,255,255,0.15); color: ${textColor};`}>{tag}</span>)}
    </div>
  )}
</a>
{cardCustomStyles && <style set:html={cardCustomStyles.replaceAll(':card', `[data-post="${slug}"]`)} />}

<style>
  .vibe-saturated-field-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    background: var(--field-color);
    color: var(--text-color);
    text-decoration: none;
    padding: var(--space-lg) var(--space-md);
    min-height: 320px;
    border-radius: var(--radius);
    transition: transform 0.4s var(--transition-spring),
                box-shadow 0.3s var(--transition-smooth);
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
  }
  .vibe-saturated-field-card__inner {
    max-width: 85%;
  }
  .vibe-saturated-field-card .card__title {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1.15;
    margin-top: var(--space-xs);
    text-transform: var(--font-display-transform);
    transition: letter-spacing 0.4s var(--transition-smooth);
  }
  .vibe-saturated-field-card:hover .card__title {
    letter-spacing: 0.03em;
  }
  .vibe-saturated-field-card .card__date {
    opacity: 0.5;
    margin-top: auto;
    padding-top: var(--space-md);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  .vibe-saturated-field-card:hover {
    transform: scale(1.03);
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .vibe-saturated-field-card:focus-visible {
    outline: 3px solid var(--text-color);
    outline-offset: 4px;
  }
</style>
