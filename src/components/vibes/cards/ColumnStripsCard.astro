---
import { ensureContrast, getCompositionProps, compositionStyles, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  vibeProps: Record<string, string>;
  cardCustomStyles?: string;
}

const { title, description, date, type, href, slug, tags, index = 0, vibeProps, cardCustomStyles } = Astro.props;
const stripCount = parseInt(vibeProps.stripCount ?? '3');
const ratiosStr = vibeProps.stripRatios ?? '30,40,30';
const ratios = ratiosStr.split(',').map(r => r.trim());
const colorsStr = vibeProps.stripColors ?? '#1a2744,#f5f0eb,#ff6b35';
const colors = colorsStr.split(',').map(c => c.trim());
const activeStrip = parseInt(vibeProps.activeStrip ?? '2') - 1;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compStyle = compositionStyles(cp);
const compClass = compositionClasses(cp);

const strips: { color: string; width: string }[] = [];
for (let i = 0; i < stripCount; i++) {
  strips.push({
    color: colors[i % colors.length] || '#1a1a1a',
    width: (ratios[i] || `${100 / stripCount}`) + '%',
  });
}

const activeColor = strips[activeStrip]?.color ?? '#f5f0eb';
const textColor = ensureContrast(activeColor, '#1a1a1a');
---

<a
  href={href}
  class:list={['vibe-column-strips-card', compClass]}
  data-post={slug}
  style={`--i: ${index}; --text-color: ${textColor}; ${compStyle}`}
>
  <div class="vibe-column-strips-card__strips" aria-hidden="true">
    {strips.map((s, i) => (
      <div
        class:list={['vibe-column-strips-card__strip', { 'vibe-column-strips-card__strip--active': i === activeStrip }]}
        style={`background: ${s.color}; width: ${s.width};`}
      />
    ))}
  </div>
  <div class="vibe-column-strips-card__content" style={`left: ${ratios.slice(0, activeStrip).reduce((a, b) => a + parseFloat(b), 0)}%; width: ${ratios[activeStrip] ?? 33}%;`}>
    <span class="card__type">{type}</span>
    <h2 class="card__title">{title}</h2>
    <time class="card__date" datetime={date.toISOString()}>{formattedDate}</time>
  </div>
</a>
{cardCustomStyles && <style set:html={cardCustomStyles.replaceAll(':card', `[data-post="${slug}"]`)} />}

<style>
  .vibe-column-strips-card {
    display: block;
    position: relative;
    text-decoration: none;
    color: var(--text-color);
    min-height: 360px;
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.4s var(--transition-spring);
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
  }
  .vibe-column-strips-card__strips {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: row;
  }
  .vibe-column-strips-card__strip {
    height: 100%;
    flex-shrink: 0;
  }
  .vibe-column-strips-card__content {
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-md);
  }
  .vibe-column-strips-card .card__type {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: var(--space-xs);
  }
  .vibe-column-strips-card .card__title {
    font-family: var(--font-display);
    font-size: calc(var(--title-scale, 1) * 1.4rem);
    font-weight: var(--title-weight, 400);
    line-height: var(--title-leading, 1.2);
    text-transform: var(--font-display-transform);
    margin-bottom: var(--space-xs);
  }
  .vibe-column-strips-card .card__date {
    font-size: 0.75rem;
    opacity: 0.5;
    letter-spacing: 0.05em;
  }
  .vibe-column-strips-card:hover {
    transform: scale(1.02);
  }
  .vibe-column-strips-card:focus-visible {
    outline: 3px solid var(--text-color);
    outline-offset: 4px;
  }
  @media (max-width: 720px) {
    .vibe-column-strips-card__content {
      left: 0 !important;
      width: 100% !important;
    }
  }
</style>
