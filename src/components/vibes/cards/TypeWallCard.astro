---
import { ensureContrast, getCompositionProps, compositionStyles, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  vibeProps: Record<string, string>;
  cardCustomStyles?: string;
  hideTitle?: boolean;
}

const { title, description, date, type, href, slug, tags, index = 0, vibeProps, cardCustomStyles, hideTitle } = Astro.props;
const typeMode = vibeProps.typeMode ?? 'stacked';
const typeFill = vibeProps.typeFill !== 'false';
const fieldColor = vibeProps.fieldColor ?? '#f5f0eb';
const typeColor = ensureContrast(fieldColor, vibeProps.typeColor ?? '#1a1a1a');
const typeOpacity = vibeProps.typeOpacity ?? '1';
const lineCount = vibeProps.lineCount ?? 'auto';
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compStyle = compositionStyles(cp);
const compClass = compositionClasses(cp);

const titleWords = title.split(' ');
const lines: string[] = [];
if (lineCount !== 'auto' && parseInt(lineCount) > 1) {
  const perLine = Math.ceil(titleWords.length / parseInt(lineCount));
  for (let i = 0; i < titleWords.length; i += perLine) {
    lines.push(titleWords.slice(i, i + perLine).join(' '));
  }
} else {
  lines.push(title);
}
---

<a
  href={href}
  class:list={['vibe-type-wall-card', `vibe-type-wall-card--${typeMode}`, compClass]}
  data-post={slug}
  style={`--i: ${index}; --field-color: ${fieldColor}; --type-color: ${typeColor}; --type-opacity: ${typeOpacity}; ${compStyle}`}
>
  {cp.overlayText && (
    <span class="comp-overlay-text" style={`color: ${cp.overlayColor || typeColor}; opacity: 0.06; mix-blend-mode: ${cp.overlayBlend};`}>
      {cp.overlayText}
    </span>
  )}
  {!hideTitle && <span class="card__type" style={`color: ${typeColor}; opacity: 0.5;`}>{type}</span>}
  {!hideTitle && <div class="vibe-type-wall-card__type-block">
    {typeMode === 'single-glyph' ? (
      <h2 class="card__title vibe-type-wall-card__glyph">{title.charAt(0)}</h2>
    ) : (
      lines.map(line => (
        <h2 class="card__title vibe-type-wall-card__line">{line}</h2>
      ))
    )}
  </div>}
  {!hideTitle && <time class="card__date" datetime={date.toISOString()} style={`color: ${typeColor}; opacity: 0.4;`}>{formattedDate}</time>}
</a>
{cardCustomStyles && <style set:html={cardCustomStyles.replaceAll(':card', `[data-post="${slug}"]`)} />}

<style>
  .vibe-type-wall-card {
    display: flex;
    flex-direction: column;
    background: var(--field-color);
    color: var(--type-color);
    text-decoration: none;
    padding: var(--density-pad, var(--space-md));
    min-height: 360px;
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    transition: transform 0.4s var(--transition-spring);
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
  }
  .vibe-type-wall-card__type-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }
  .vibe-type-wall-card__line {
    font-family: var(--font-display);
    font-size: calc(var(--title-scale, 1) * 3rem);
    font-weight: var(--title-weight, 900);
    line-height: var(--title-leading, 0.9);
    text-transform: var(--font-display-transform, uppercase);
    opacity: var(--type-opacity);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .vibe-type-wall-card--stacked .vibe-type-wall-card__line {
    font-size: calc(var(--title-scale, 1) * clamp(2rem, 8vw, 4.5rem));
  }
  .vibe-type-wall-card__glyph {
    font-family: var(--font-display);
    font-size: calc(var(--title-scale, 1) * clamp(8rem, 25vw, 18rem));
    font-weight: var(--title-weight, 900);
    line-height: 0.8;
    text-transform: var(--font-display-transform, uppercase);
    opacity: var(--type-opacity);
    text-align: center;
  }
  .vibe-type-wall-card--overlap .vibe-type-wall-card__line {
    margin-top: -0.15em;
  }
  .vibe-type-wall-card .card__type {
    position: relative;
    z-index: 1;
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }
  .vibe-type-wall-card .card__date {
    position: relative;
    z-index: 1;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    margin-top: auto;
    padding-top: var(--space-sm);
  }
  .vibe-type-wall-card:hover {
    transform: scale(1.02);
  }
  .vibe-type-wall-card:focus-visible {
    outline: 3px solid var(--type-color);
    outline-offset: 4px;
  }
</style>
