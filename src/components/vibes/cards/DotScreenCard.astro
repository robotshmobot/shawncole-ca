---
import { ensureContrast, getCompositionProps, compositionStyles, compositionClasses } from '../vibeDefaults';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  href: string;
  slug: string;
  image?: string;
  color?: string;
  tags?: string[];
  index?: number;
  vibeProps: Record<string, string>;
  cardCustomStyles?: string;
}

const { title, description, date, type, href, slug, tags, index = 0, vibeProps, cardCustomStyles } = Astro.props;
const fieldColor = vibeProps.fieldColor ?? '#1a1a2e';
const dotColor = vibeProps.dotColor ?? '#e94560';
const dotSize = vibeProps.dotSize ?? '8';
const dotSpacing = vibeProps.dotSpacing ?? '24';
const dotPattern = vibeProps.dotPattern ?? 'grid';
const textColor = ensureContrast(fieldColor, vibeProps.textColor ?? '#f5f0eb');
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const cp = getCompositionProps(vibeProps);
const compStyle = compositionStyles(cp);
const compClass = compositionClasses(cp);

const dotSizePx = parseInt(dotSize);
const dotSpacingPx = parseInt(dotSpacing);
const patternSize = dotSizePx + dotSpacingPx;

let bgPattern: string;
if (dotPattern === 'diagonal') {
  bgPattern = `radial-gradient(circle, ${dotColor} ${dotSizePx / 2}px, transparent ${dotSizePx / 2}px)`;
} else if (dotPattern === 'halftone') {
  bgPattern = `radial-gradient(circle, ${dotColor} ${dotSizePx / 2}px, transparent ${dotSizePx / 2}px)`;
} else {
  bgPattern = `radial-gradient(circle, ${dotColor} ${dotSizePx / 2}px, transparent ${dotSizePx / 2}px)`;
}
---

<a
  href={href}
  class:list={['vibe-dot-screen-card', `vibe-dot-screen-card--${dotPattern}`, compClass]}
  data-post={slug}
  style={`--i: ${index}; --field-color: ${fieldColor}; --text-color: ${textColor}; --dot-color: ${dotColor}; --dot-size: ${dotSizePx}px; --dot-spacing: ${dotSpacingPx}px; --pattern-size: ${patternSize}px; ${compStyle}`}
>
  <div class="vibe-dot-screen-card__dots" aria-hidden="true"></div>
  <div class="vibe-dot-screen-card__content">
    <span class="card__type">{type}</span>
    <h2 class="card__title">{title}</h2>
    <p class="card__description">{description}</p>
    <time class="card__date" datetime={date.toISOString()}>{formattedDate}</time>
  </div>
</a>
{cardCustomStyles && <style set:html={cardCustomStyles.replaceAll(':card', `[data-post="${slug}"]`)} />}

<style>
  .vibe-dot-screen-card {
    display: flex;
    flex-direction: column;
    background: var(--field-color);
    color: var(--text-color);
    text-decoration: none;
    min-height: 360px;
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    transition: transform 0.4s var(--transition-spring);
    animation: slideUp 0.6s var(--transition-smooth) both;
    animation-delay: calc(var(--i, 0) * 0.08s);
    cursor: crosshair;
  }
  .vibe-dot-screen-card__dots {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    transition: opacity 0.4s var(--transition-smooth);
  }
  .vibe-dot-screen-card--grid .vibe-dot-screen-card__dots {
    background-image: radial-gradient(circle, var(--dot-color) calc(var(--dot-size) / 2), transparent calc(var(--dot-size) / 2));
    background-size: var(--pattern-size) var(--pattern-size);
  }
  .vibe-dot-screen-card--diagonal .vibe-dot-screen-card__dots {
    background-image: radial-gradient(circle, var(--dot-color) calc(var(--dot-size) / 2), transparent calc(var(--dot-size) / 2));
    background-size: var(--pattern-size) var(--pattern-size);
    transform: rotate(45deg) scale(1.5);
  }
  .vibe-dot-screen-card--halftone .vibe-dot-screen-card__dots {
    background-image:
      radial-gradient(circle, var(--dot-color) calc(var(--dot-size) / 2), transparent calc(var(--dot-size) / 2)),
      radial-gradient(circle, var(--dot-color) calc(var(--dot-size) / 3), transparent calc(var(--dot-size) / 3));
    background-size:
      var(--pattern-size) var(--pattern-size),
      calc(var(--pattern-size) / 2) calc(var(--pattern-size) / 2);
    background-position:
      0 0,
      calc(var(--pattern-size) / 4) calc(var(--pattern-size) / 4);
  }
  .vibe-dot-screen-card__content {
    position: relative;
    z-index: 1;
    padding: var(--density-pad, var(--space-md));
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: flex-end;
  }
  .vibe-dot-screen-card .card__type {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: var(--space-xs);
  }
  .vibe-dot-screen-card .card__title {
    font-family: var(--font-display);
    font-size: calc(var(--title-scale, 1) * 1.8rem);
    font-weight: var(--title-weight, 800);
    line-height: var(--title-leading, 1.15);
    text-transform: var(--font-display-transform);
    margin-bottom: var(--space-xs);
  }
  .vibe-dot-screen-card .card__description {
    font-size: 0.9rem;
    opacity: 0.7;
    line-height: 1.5;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .vibe-dot-screen-card .card__date {
    font-size: 0.75rem;
    opacity: 0.4;
    letter-spacing: 0.05em;
  }
  .vibe-dot-screen-card:hover {
    transform: scale(1.02);
  }
  .vibe-dot-screen-card:hover .vibe-dot-screen-card__dots {
    opacity: 0.6;
  }
  .vibe-dot-screen-card:focus-visible {
    outline: 3px solid var(--text-color);
    outline-offset: 4px;
  }
</style>
