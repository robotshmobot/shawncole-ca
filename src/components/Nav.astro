---
interface Props {
  currentPath?: string;
  isDetailPage?: boolean;
}

const { currentPath = '/', isDetailPage = false } = Astro.props;

const navItems = [
  { label: 'ALL THE THINGS', href: '/' },
  { label: 'CASE STUDIES', href: '/case-studies' },
  { label: 'FUTURES', href: '/futures' },
  { label: 'IDEAS', href: '/ideas' },
  { label: 'PLAYGROUND', href: '/playground' },
  { label: 'ABOUT SHAWN', href: '/about' },
  { label: 'CONTACT', href: 'mailto:shawnr.cole@gmail.com' },
];

function isActive(href: string, current: string) {
  if (href === '/') return current === '/';
  if (href.startsWith('mailto:')) return false;
  return current.startsWith(href);
}
---

<nav class="site-nav" data-nav>
  <div class="site-nav__menu" data-nav-menu>
    {navItems.map(item => (
      <a
        href={item.href}
        class:list={['site-nav__link', { 'site-nav__link--active': isActive(item.href, currentPath) }]}
      >
        {item.label}
      </a>
    ))}
  </div>
  <div class="site-nav__bar">
    {isDetailPage && (
      <a href="javascript:history.back()" class="site-nav__back" aria-label="Go back" data-nav-back>
        <img src="/img/icon-back.svg" alt="" width="28" height="28" />
      </a>
    )}
    {!isDetailPage && <span class="site-nav__name">SHAWN COLE</span>}
    <button class="site-nav__toggle" data-nav-toggle aria-label="Toggle menu" aria-expanded="false">
      <img class="site-nav__icon-menu" src="/img/icon-menu.svg" alt="" width="28" height="28" />
      <img class="site-nav__icon-close" src="/img/icon-close.svg" alt="" width="28" height="28" />
    </button>
  </div>
</nav>

<style>
  .site-nav {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: 16px;
    background: #B3FF38;
    z-index: 1000;
    text-transform: uppercase;
    filter: drop-shadow(0px 12px 16px rgba(51, 51, 76, 0.25));
  }

  .site-nav__menu {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 15px 24px 0;
  }

  .site-nav[data-open] .site-nav__menu {
    display: flex;
  }

  .site-nav__link {
    font-family: 'SRC Marker', var(--font-body);
    color: #12121a;
    text-decoration: none;
    font-size: 22px;
    line-height: 1.25;
    white-space: nowrap;
    padding: 2px 6px;
    transition: background 0.15s, color 0.15s;
  }

  .site-nav__link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    text-decoration-color: #12121a;
  }

  .site-nav__link--active {
    background: #12121a;
    color: #B3FF38;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    text-decoration-color: #12121a;
  }

  .site-nav__link:focus-visible {
    outline: 2px solid #1a1a1a;
    outline-offset: 4px;
    border-radius: 2px;
  }

  .site-nav__bar {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 48px;
    padding: 0 24px;
  }

  .site-nav__back {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    text-decoration: none;
    padding: 4px;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .site-nav__back:hover {
    background: rgba(0, 0, 0, 0.1);
  }

  .site-nav__name {
    font-family: 'SRC Marker', var(--font-body);
    color: #12121a;
    font-size: 22px;
    line-height: 1.25;
  }

  .site-nav__toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .site-nav__toggle:hover {
    background: rgba(0, 0, 0, 0.15);
  }

  .site-nav__toggle:focus-visible {
    outline: 2px solid #1a1a1a;
    outline-offset: 2px;
  }

  .site-nav__icon-close {
    display: none;
  }

  .site-nav[data-open] .site-nav__icon-menu {
    display: none;
  }

  .site-nav[data-open] .site-nav__icon-close {
    display: block;
  }

  @media (max-width: 640px) {
    .site-nav {
      left: 32px;
      right: 32px;
      transform: none;
      width: auto;
    }

    .site-nav__bar {
      justify-content: space-between;
      width: 100%;
    }
  }
</style>

<script>
  function initNav() {
    const toggle = document.querySelector('[data-nav-toggle]');
    const nav = document.querySelector('[data-nav]');
    if (!toggle || !nav) return;

    toggle.addEventListener('click', () => {
      const isOpen = nav.hasAttribute('data-open');
      if (isOpen) {
        nav.removeAttribute('data-open');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        nav.setAttribute('data-open', '');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
