---
import { getCollection } from 'astro:content';
import PosterCard from './PosterCard.astro';
import type { FontPairing } from '../utils/fonts';
import { getFontPairing } from '../utils/fonts';

interface Props {
  filter?: string;
}

const { filter } = Astro.props;

const caseStudies = await getCollection('case-studies');
const futures = await getCollection('futures');
const ideas = await getCollection('ideas');

type ContentEntry = {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    tags?: string[];
    image?: string;
    color?: string;
    fontPairing?: FontPairing;
    hideTitle?: boolean;
  };
  type: string;
  href: string;
};

const allContent: ContentEntry[] = [
  ...caseStudies.map((entry) => ({
    ...entry,
    type: 'case study',
    href: `/case-studies/${entry.id}`,
  })),
  ...futures.map((entry) => ({
    ...entry,
    type: 'futures',
    href: `/futures/${entry.id}`,
  })),
  ...ideas.map((entry) => ({
    ...entry,
    type: 'idea',
    href: `/ideas/${entry.id}`,
  })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const filteredContent = filter
  ? allContent.filter((entry) => entry.type === filter)
  : allContent;
---

<div class="card-feed">
  {
    filteredContent.map((entry, i) => (
      <PosterCard
        title={entry.data.title}
        description={entry.data.description}
        date={entry.data.date}
        type={entry.type}
        href={entry.href}
        slug={entry.id}
        image={entry.data.image}
        color={entry.data.color}
        tags={entry.data.tags}
        fontPairing={getFontPairing(entry.data.fontPairing, entry.id)}
        index={i}
      />
    ))
  }
</div>
