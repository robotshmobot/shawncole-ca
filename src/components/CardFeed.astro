---
import { getCollection } from 'astro:content';
import VibeCard from './vibes/VibeCard.astro';
import type { VibeName, FontPairing } from './vibes/vibeDefaults';
import { getFontPairing } from './vibes/vibeDefaults';

const blog = await getCollection('blog');
const caseStudies = await getCollection('case-studies');
const stories = await getCollection('stories');
const futures = await getCollection('futures');

type ContentEntry = {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    tags?: string[];
    image?: string;
    color?: string;
    cardCustomStyles?: string;
    vibe?: VibeName;
    vibeProps?: Record<string, string>;
    span?: string;
    fontPairing?: FontPairing;
  };
  type: string;
  href: string;
};

const allContent: ContentEntry[] = [
  ...blog.map((entry) => ({
    ...entry,
    type: 'blog',
    href: `/blog/${entry.id}`,
  })),
  ...caseStudies.map((entry) => ({
    ...entry,
    type: 'case study',
    href: `/case-studies/${entry.id}`,
  })),
  ...stories.map((entry) => ({
    ...entry,
    type: 'story',
    href: `/stories/${entry.id}`,
  })),
  ...futures.map((entry) => ({
    ...entry,
    type: 'futures',
    href: `/futures/${entry.id}`,
  })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<div class="card-feed">
  {
    allContent.map((entry, i) => (
      <VibeCard
        title={entry.data.title}
        description={entry.data.description}
        date={entry.data.date}
        type={entry.type}
        href={entry.href}
        slug={entry.id}
        image={entry.data.image}
        color={entry.data.color}
        tags={entry.data.tags}
        cardCustomStyles={entry.data.cardCustomStyles}
        vibe={entry.data.vibe}
        vibeProps={entry.data.vibeProps}
        span={entry.data.span}
        fontPairing={getFontPairing(entry.data.fontPairing, entry.id)}
        index={i}
      />
    ))
  }
</div>
