---
import { getCollection } from 'astro:content';
import VibeCard from './vibes/VibeCard.astro';
import PosterCard from './PosterCard.astro';
import type { VibeName, FontPairing } from './vibes/vibeDefaults';
import { getFontPairing } from './vibes/vibeDefaults';

interface Props {
  filter?: string;
  variant?: 'vibe' | 'poster';
}

const { filter, variant = 'vibe' } = Astro.props;

const caseStudies = await getCollection('case-studies');
const futures = await getCollection('futures');
const ideas = await getCollection('ideas');

type ContentEntry = {
  id: string;
  data: {
    title: string;
    description: string;
    date: Date;
    tags?: string[];
    image?: string;
    color?: string;
    cardCustomStyles?: string;
    vibe?: VibeName;
    vibeProps?: Record<string, string>;
    span?: string;
    fontPairing?: FontPairing;
    hideTitle?: boolean;
  };
  type: string;
  href: string;
};

const allContent: ContentEntry[] = [
  ...caseStudies.map((entry) => ({
    ...entry,
    type: 'case study',
    href: `/case-studies/${entry.id}`,
  })),
  ...futures.map((entry) => ({
    ...entry,
    type: 'futures',
    href: `/futures/${entry.id}`,
  })),
  ...ideas.map((entry) => ({
    ...entry,
    type: 'idea',
    href: `/ideas/${entry.id}`,
  })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const filteredContent = filter
  ? allContent.filter((entry) => entry.type === filter)
  : allContent;
---

<div class="card-feed">
  {
    filteredContent.map((entry, i) => (
      variant === 'poster' ? (
        <PosterCard
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          type={entry.type}
          href={entry.href}
          slug={entry.id}
          image={entry.data.image}
          color={entry.data.color}
          fontPairing={getFontPairing(entry.data.fontPairing, entry.id)}
          index={i}
        />
      ) : (
        <VibeCard
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          type={entry.type}
          href={entry.href}
          slug={entry.id}
          image={entry.data.image}
          color={entry.data.color}
          tags={entry.data.tags}
          cardCustomStyles={entry.data.cardCustomStyles}
          vibe={entry.data.vibe}
          vibeProps={entry.data.vibeProps}
          span={entry.data.span}
          fontPairing={getFontPairing(entry.data.fontPairing, entry.id)}
          hideTitle={entry.data.hideTitle}
          index={i}
        />
      )
    ))
  }
</div>
