---
import { getCollection, render } from 'astro:content';
import Post from '../../layouts/Post.astro';
import { getFontPairing } from '../../utils/fonts';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Post
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  type="case study"
  image={entry.data.image}
  color={entry.data.color}
  tags={entry.data.tags}
  customStyles={entry.data.customStyles}
  fontPairing={getFontPairing(entry.data.fontPairing, entry.id)}
  hideTitle={entry.data.hideTitle}
  clientLogo={entry.data.clientLogo}
  clientName={entry.data.clientName}
  role={entry.data.role}
  projectDate={entry.data.projectDate}
  lede={entry.data.lede}
>
  <Content />
</Post>
