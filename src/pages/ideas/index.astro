---
import Base from '../../layouts/Base.astro';
import CardFeed from '../../components/CardFeed.astro';
---

<Base title="Ideas — shawncole.ca">
  <main class="category">
    <h1 class="category__title">Ideas</h1>
    <div class="category__feed">
      <CardFeed filter="idea" />
    </div>
  </main>
</Base>

<style>
  .category {
    padding: 40px 40px 120px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .category__title {
    font-family: 'SRC Marker', var(--font-body);
    font-size: 64px;
    font-weight: 400;
    text-align: center;
    text-transform: uppercase;
    color: var(--color-dark);
    margin-bottom: 64px;
  }

  .category__feed {
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    .category__title {
      font-size: 48px;
    }

    .category__feed {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .category {
      padding: 16px 16px 120px;
    }

    .category__title {
      font-size: 32px;
      margin-bottom: 16px;
    }
  }
</style>
