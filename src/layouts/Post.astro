---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  fontPairing?: string;
}

const { title, description, date, type, image, color, tags, customStyles, fontPairing } = Astro.props;

const typeColorMap: Record<string, string> = {
  'futures': 'var(--color-cherry)',
  'case study': 'var(--color-lime)',
  'idea': '#ffffff',
};
const pillTextColor = typeColorMap[type] ?? '#ffffff';

const pageBg = color || '#ffffff';
const heroBg = color || '#f0f0f0';
const resolvedImage = image && !image.startsWith('/') && !image.startsWith('http') ? `/${image}` : image;
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class="detail" style={`--detail-bg: ${pageBg}; --hero-bg: ${heroBg};`}>
    <header class="detail__hero">
      {resolvedImage && (
        <img src={resolvedImage} alt={title} class="detail__hero-image" />
      )}
      <div class="detail__hero-content">
        <h1 class="detail__title">{title}</h1>
        <div class="detail__pill">
          <span class="detail__type" style={`color: ${pillTextColor};`}>{type}</span>
        </div>
      </div>
    </header>

    <div class="detail__body">
      <div class="detail__content">
        <slot />
      </div>
    </div>

    <footer class="detail__footer">
      <div class="detail__callout">
        <p class="detail__callout-text">
          If this sparked something, <a href="mailto:shawnr.cole@gmail.com" class="detail__callout-link">let's talk about it</a>.
        </p>
      </div>
    </footer>
  </article>
  {customStyles && <style set:html={customStyles} />}
</Base>

<style>
  .detail {
    background: var(--detail-bg, #ffffff);
    min-height: 100vh;
  }

  .detail__hero {
    position: relative;
    width: 100%;
    max-width: 1432px;
    margin: 0 auto;
    height: clamp(400px, 60vw, 946px);
    background: var(--hero-bg, #f0f0f0);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: darken;
    transform: rotate(-1deg) scale(1.02);
    pointer-events: none;
  }

  .detail__hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 40px;
  }

  .detail__title {
    font-family: var(--font-display);
    font-size: clamp(48px, 10vw, 128px);
    font-weight: 400;
    line-height: 1;
    color: white;
    text-transform: var(--font-display-transform);
    margin-bottom: 24px;
  }

  .detail__pill {
    display: inline-flex;
    align-items: center;
    background: var(--color-dark);
    padding: 6px 16px;
  }

  .detail__type {
    font-family: 'Geist Mono', monospace;
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .detail__body {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 40px 0;
  }

  .detail__content {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 17px;
    line-height: 1.35;
    color: var(--color-dark);
  }

  .detail__content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    margin: 64px 0 24px;
    text-transform: var(--font-display-transform);
    color: var(--color-dark);
  }

  .detail__content :global(h3) {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 48px 0 16px;
    color: var(--color-dark);
  }

  .detail__content :global(p) {
    margin-bottom: 24px;
  }

  .detail__content :global(blockquote) {
    border-left: 3px solid var(--color-dark);
    padding-left: 24px;
    color: var(--color-dark);
    opacity: 0.7;
    font-style: italic;
    margin: 32px 0;
  }

  .detail__content :global(hr) {
    border: none;
    width: 240px;
    height: 1px;
    background: var(--color-dark);
    opacity: 0.2;
    margin: 64px auto;
  }

  .detail__content :global(img) {
    width: calc(100% + 80px);
    margin-left: -40px;
    height: auto;
    border-radius: 16px;
    margin-top: 32px;
    margin-bottom: 32px;
    display: block;
  }

  .detail__content :global(code) {
    font-family: 'Geist Mono', monospace;
    font-size: 0.85em;
    background: rgba(0, 0, 0, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .detail__content :global(pre) {
    background: var(--color-dark);
    color: #f0f0f0;
    padding: 24px;
    border-radius: 16px;
    overflow-x: auto;
    margin: 32px 0;
    font-size: 0.9em;
  }

  .detail__content :global(pre code) {
    background: none;
    padding: 0;
  }

  .detail__content :global(a) {
    color: #0d0eda;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .detail__content :global(strong) {
    font-weight: 600;
  }

  .detail__footer {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 40px 120px;
  }

  .detail__callout {
    background: #ffffff;
    border-radius: 64px;
    padding: 64px;
    text-align: center;
  }

  .detail__callout-text {
    font-family: 'SRC Marker', var(--font-body);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.3;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .detail__callout-link {
    color: #0d0eda;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }

  @media (max-width: 640px) {
    .detail__hero {
      height: 300px;
    }

    .detail__title {
      font-size: 36px;
    }

    .detail__body {
      padding: 40px 20px 0;
    }

    .detail__content :global(img) {
      width: calc(100% + 40px);
      margin-left: -20px;
    }

    .detail__footer {
      padding: 40px 20px 120px;
    }

    .detail__callout {
      border-radius: 32px;
      padding: 32px;
    }
  }
</style>
