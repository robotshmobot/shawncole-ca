---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  type: string;
  image?: string;
  color?: string;
  tags?: string[];
  customStyles?: string;
  fontPairing?: string;
  hideTitle?: boolean;
  footer?: string;
  clientLogo?: string;
  clientName?: string;
  role?: string;
  projectDate?: string;
  lede?: string;
}

const { title, description, date, type, image, color, tags, customStyles, fontPairing, hideTitle, footer, clientLogo, clientName, role, projectDate, lede } = Astro.props;
const hasDetails = clientLogo || role || projectDate;

const typeColorMap: Record<string, string> = {
  'futures': 'var(--color-cherry)',
  'case study': 'var(--color-lime)',
  'idea': '#ffffff',
};
const pillTextColor = typeColorMap[type] ?? '#ffffff';

const pageBg = color || '#ffffff';
const heroBg = image ? '#f0f0f0' : (color || '#f0f0f0');
const resolvedImage = image && !image.startsWith('/') && !image.startsWith('http') ? `/${image}` : image;
---

<Base title={`${title} — shawncole.ca`} fontPairing={fontPairing}>
  <article class="detail" style={`--detail-bg: ${pageBg}; --hero-bg: ${heroBg};`}>
    <header class="detail__hero">
      {resolvedImage && (
        <img src={resolvedImage} alt={title} class="detail__hero-image" />
      )}
      {!hideTitle && (
        <div class="detail__hero-content">
          <h1 class="detail__title">{title}</h1>
          <div class="detail__pill">
            <span class="detail__type" style={`color: ${pillTextColor};`}>{type}</span>
          </div>
        </div>
      )}
    </header>

    {hasDetails && (
      <div class="detail__intro">
        <div class="detail__details">
          {clientLogo && (
            <div class="detail__detail-group">
              <span class="detail__detail-label">Client</span>
              <img src={clientLogo} alt={clientName || ''} class="detail__client-logo" />
            </div>
          )}
          {role && (
            <div class="detail__detail-group">
              <span class="detail__detail-label">Role</span>
              <span class="detail__detail-value">{role}</span>
            </div>
          )}
          {projectDate && (
            <div class="detail__detail-group">
              <span class="detail__detail-label">Project date</span>
              <span class="detail__detail-value">{projectDate}</span>
            </div>
          )}
        </div>
        {lede && (
          <p class="detail__lede">{lede}</p>
        )}
      </div>
    )}

    <div class="detail__body">
      <div class="detail__content">
        <slot />
      </div>
    </div>

    <footer class="detail__footer">
      {footer ? (
        <div class="detail__footer-box" set:html={footer.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="detail__footer-link action-link">$1</a>')} />
      ) : (
        <div class="detail__callout">
          <p class="detail__callout-text">
            If this sparked something, <a href="#contact" class="detail__callout-link action-link" data-open-contact>let's&nbsp;talk&nbsp;about&nbsp;it&nbsp;></a>
          </p>
        </div>
      )}
    </footer>
  </article>
  {customStyles && <style set:html={customStyles} />}
  <style is:global>
    body:has(.detail) {
      max-width: none;
      padding-left: 0;
      padding-right: 0;
    }
  </style>
</Base>

<style>
  .detail {
    background: var(--detail-bg, #ffffff);
    min-height: 100vh;
    padding-bottom: 128px;
  }

  .detail__hero {
    position: relative;
    width: 100%;
    max-width: 2400px;
    margin: 0 auto;
    height: 66vh;
    background: var(--hero-bg, #f0f0f0);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    mix-blend-mode: darken;
    transform: scale(1.02);
    pointer-events: none;
  }

  .detail__hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 40px;
  }

  .detail__title {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 400;
    line-height: 1;
    color: white;
    text-transform: var(--font-display-transform);
    filter: drop-shadow(0px 12px 16px rgba(51, 51, 76, 0.33));
  }

  .detail__pill {
    display: inline-flex;
    align-items: center;
    background: var(--color-dark);
    padding: 6px 16px;
    margin-top: 16px;
  }

  .detail__type {
    font-family: 'Geist Mono', monospace;
    font-size: 16px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .detail__intro {
    display: flex;
    align-items: center;
    gap: 64px;
    align-self: stretch;
    max-width: 1512px;
    margin: 0 auto;
    padding: 64px 40px 0;
  }

  .detail__details {
    background: #ffffff;
    border-radius: 32px;
    padding: 32px;
    width: 360px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
    overflow: hidden;
  }

  .detail__detail-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .detail__detail-label {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.25;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .detail__client-logo {
    height: 64px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    object-position: left;
  }

  .detail__detail-value {
    font-family: 'Geist', var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-dark);
  }

  .detail__lede {
    font-family: var(--font-body, 'Source Serif 4', Georgia, serif);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-dark);
    flex: 1;
    min-width: 0;
  }

  .detail__body {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 40px 0;
  }

  .detail__content {
    font-family: var(--font-body, 'Source Serif 4', Georgia, serif);
    font-size: 17px;
    line-height: 1.35;
    color: var(--color-dark);
  }

  .detail__content :global(h2) {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1;
    margin: 64px 0 24px;
    text-transform: var(--font-display-transform);
    color: var(--color-dark);
  }

  .detail__content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    margin: 48px 0 16px;
    text-transform: var(--font-display-transform);
    color: var(--color-dark);
  }

  .detail__content :global(p) {
    margin-bottom: 24px;
  }

  .detail__content :global(blockquote) {
    border-left: 3px solid var(--color-dark);
    padding-left: 24px;
    color: var(--color-dark);
    opacity: 0.7;
    font-style: italic;
    margin: 32px 0;
  }

  .detail__content :global(blockquote p) {
    margin-bottom: 0;
  }

  .detail__content :global(hr) {
    border: none;
    width: 240px;
    height: 1px;
    background: var(--color-dark);
    opacity: 0.2;
    margin: 64px auto;
  }

  .detail__content :global(img) {
    width: calc(100% + 80px);
    margin-left: -40px;
    height: auto;
    border-radius: 16px;
    margin-top: 32px;
    margin-bottom: 16px;
    display: block;
  }

  .detail__content :global(code) {
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    background: rgba(0, 0, 0, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .detail__content :global(pre) {
    background: var(--color-dark);
    color: #f0f0f0;
    padding: 24px;
    border-radius: 16px;
    overflow-x: auto;
    margin: 32px 0;
    font-size: 0.7rem;
  }

  .detail__content :global(pre code) {
    background: none;
    padding: 0;
  }

  .detail__content :global(a) {
    color: #0d0eda;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .detail__content :global(strong) {
    font-weight: 600;
  }

  .detail__content :global(ul),
  .detail__content :global(ol) {
    padding-left: 16px;
    margin: 24px 0;
    list-style-position: outside;
  }

  .detail__content :global(li) {
    margin-bottom: 8px;
  }

  .detail__content :global(li)::marker {
    font-size: 0.8em;
  }

  .detail__content :global(table) {
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
    margin: 32px 0;
  }

  .detail__content :global(th),
  .detail__content :global(td) {
    border: 1px solid var(--color-dark);
    padding: 16px;
    text-align: left;
    vertical-align: top;
  }

  .detail__content :global(th) {
    border-bottom: none;
  }

  .detail__content :global(td) {
    border-top: none;
  }

  .detail__content :global(th) {
    font-family: 'Geist Mono', monospace;
    font-size: 64px;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .detail__content :global(td) {
    font-family: 'Geist', var(--font-body);
    font-size: 12px;
    line-height: 1.35;
    color: var(--color-dark);
    opacity: 0.5;
  }

  .detail__footer {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 40px 0;
  }

  .detail__callout {
    background: #ffffff;
    border-radius: 64px;
    padding: 64px;
    text-align: center;
  }

  .detail__callout-text {
    font-family: 'SRC Marker', var(--font-body);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.3;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .detail__callout-link {
    color: #0d0eda;
    --action-bg: #0d0eda;
    --action-fg: #fff;
  }

  .detail__footer-box {
    background: #ffffff;
    border-radius: 24px;
    padding: 48px;
    font-family: 'SRC Marker', var(--font-body);
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.5;
    text-transform: uppercase;
    color: var(--color-dark);
  }

  .detail__footer-box :global(.detail__footer-link) {
    color: #0d0eda;
    --action-bg: #0d0eda;
    --action-fg: #fff;
  }

  @media (max-width: 1024px) {
    .detail__title {
      font-size: 64px;
    }
  }

  @media (max-width: 640px) {
    .detail__title {
      font-size: 32px;
    }

    .detail__hero-content {
      padding: 0 16px;
    }

    .detail__intro {
      flex-direction: column;
      gap: 32px;
      padding: 40px 16px 0;
    }

    .detail__details {
      width: 100%;
      padding: 24px;
      border-radius: 24px;
      gap: 24px;
    }

    .detail__lede {
      font-size: 17px;
    }

    .detail__body {
      padding: 40px 16px 0;
    }

    .detail__content :global(img) {
      width: 100%;
    }

    .detail__content :global(th) {
      font-size: 32px;
      padding: 12px;
    }

    .detail__content :global(td) {
      padding: 12px;
    }

    .detail__footer {
      padding: 40px 16px 0;
    }

    .detail__callout {
      border-radius: 32px;
      padding: 32px;
    }
  }
</style>
